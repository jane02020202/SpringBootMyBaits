<?xml version="1.0" encoding="UTF-8"?> <!-- XMl 1.0 버전, 글자는 UTF-8 방식으로 읽 -->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd"> <!-- XML 파일은 MyBatis의 Mapper 규칙(3.0 버전)을 따른다"는 선언문. -->
<mapper namespace="kopo.poly.mapper.IUserInfoMapper"> <!-- 이 XML이 어떤 자바 인터페이스랑 짝을 이루는지 알려주는 부분. namespace에 IUserInfoMapper의 전체 경로를 적어서, "이 XML은 저 인터페이스의 SQL을 담당한다" -->

    <!-- 회원 가입 전 아이디 중복체크하기 / 조회 -->
    <select id="getUserIdExists" parameterType="UserInfoDTO" resultType="UserInfoDTO">
        SELECT
            IF(COUNT(USER_ID) > 0, 'Y', 'N') AS EXISTS_YN
        FROM USER_INFO
        WHERE USER_ID = #{userId}
    </select>

    <!-- 회원 가입 전 이메일 중복체크하기 -->
    <select id="getEmailExists" parameterType="UserInfoDTO" resultType="UserInfoDTO">
        SELECT
            IF(COUNT(USER_ID) > 0, 'Y', 'N') AS EXISTS_YN
        FROM USER_INFO
        WHERE EMAIL = #{email}
    </select>

    <!-- 로그인을 위해 아이디와 비밀번호가 일치하는지 확인하기 -->
    <select id="getLogin" parameterType="UserInfoDTO" resultType="UserInfoDTO">
        SELECT USER_ID, USER_NAME, EMAIL
        FROM USER_INFO
        WHERE USER_ID = #{userId}
          AND PASSWORD = #{password}
    </select>

    <!-- 아이디, 비밀번호 찾기에 활용
    1. 이름과 이메일이 맞다면, 아이디 알려주기
    2. 아이디, 이름과 이메일이 맞다면, 비밀번호 재설정하기
    -->

    <select id="getUserId" parameterType="UserInfoDTO" resultType="UserInfoDTO">
        SELECT
        USER_ID,
        USER_NAME,
        EMAIL
        FROM USER_INFO
        WHERE 1=1 <!-- 항상 참인 조건 / if절을 빠질 수도 있으니깐 제외하고 where 뒤에 바로 and 가 와서 1=1을 붙여야 함 / '일치'라는 조건을 지키기 위해 where절 씀-->
        <if test="userId neq null and userId neq ''"> <!-- userId에 값을 넣거나 안 넣거나 -->
            AND USER_ID = #{userId}

          <!--
    userId에 값이 있는지 확인 (null과 빈 문자열, 두 가지 경우 모두 체크)
    - 값이 있으면 → 비밀번호 찾기 (아이디를 이미 알고 있음) → USER_ID 조건 추가
    - 값이 없으면 → 아이디 찾기 (아이디를 모름) → USER_ID 조건 생략
    - neq null과 neq ''이 "각각" 아이디 찾기/비밀번호 찾기를 나타내는 게 아님
  -->

        </if>

        AND USER_NAME = #{userName}
        AND EMAIL = #{email}

        <!--
  이름 + 이메일 조건 (아이디 찾기, 비밀번호 찾기 두 경우 모두 공통 적용)
  - 이 두 값이 DB와 정확히 일치하는 사람만 조회됨 (본인 확인 목적)
  - 예) 아이디 찾기: 이름="홍길동", 이메일="abc@naver.com" 입력 시
        일치하는 회원이 있으면 그 사람의 USER_ID를 화면에 보여줌
        ("당신의 아이디는 hong123입니다")
-->
    </select>

    <!-- 회원 가입하기(회원정보 등록하기) -->
    <insert id="insertUserInfo" parameterType="UserInfoDTO">
        INSERT INTO USER_INFO
        (USER_ID,
         USER_NAME,
         PASSWORD,
         EMAIL,
         ADDR1,
         ADDR2,
         REG_ID, <!-- 누가 등록했는지 -->
         REG_DT, <!-- 언제 등록했는지 -->
         CHG_ID, <!-- 	CHanGe(변경) + ID = "누가 마지막으로 수정했는지" -->
         CHG_DT) <!-- 	CHanGe(변경) + DaTe(날짜) = "언제 마지막으로 수정했는지" -->
        VALUES (#{userId},
                #{userName},
                #{password},
                #{email},
                #{addr1},
                #{addr2},
                #{userId},
                NOW(),
                #{userId},
                NOW())

        <!--
  - 회원가입 시점 = 등록자와 수정자가 동일 인물(본인), 시각도 동일(NOW())
  - REG_ID = #{userId}  : 등록한 사람 = 본인
  - REG_DT = NOW()      : 등록 시각 = 가입하는 지금 이 순간
  - CHG_ID = #{userId}  : 수정한 사람 = 아직 아무도 안 고쳤으니 본인 그대로
  - CHG_DT = NOW()      : 수정 시각 = 등록 시각과 동일 (지금)
-->

    </insert>

    <!-- 비밀번호 재설정 -->

    <update id="updatePassword" parameterType="UserInfoDTO">
        UPDATE USER_INFO
        SET PASSWORD = #{password} <!-- PASSWORD 칸을, 바뀔 새 값(#{password})으로 바꿔라 -->
        WHERE USER_ID = #{userId} <!-- 그런데 아무나 바꾸면 안 되니까, 이 아이디를 가진 사람만 바꿔라 -->
        <!-- 왜 UPDATE에는 resultType이 없는지? - UPDATE는 "데이터를 바꾸기만" 하지, 뭘 조회해서 돌려주는 게 아님 -->
    </update>

</mapper>

        <!--
          ===== SQL 종류별 역할 정리 =====

          SELECT : 데이터 조회(찾기)만 함 → 아무것도 안 바뀜
                   예) 서랍을 열어서 물건이 있는지 확인만 함 (물건은 그대로)

          INSERT : 새 데이터 추가(등록) → 새 줄이 하나 생김
                   예) 서랍에 새 물건을 넣음

          UPDATE : 있던 데이터 수정(변경) → 줄 개수는 그대로, 내용만 바뀜
                   예) 서랍 안에 있던 물건의 내용물을 바꿔치기함
        -->